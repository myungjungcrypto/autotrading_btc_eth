# Runtime
PORT=8787
HOST=127.0.0.1
NODE_ENV=development
DATA_DIR=./data
MARKET_DATA_MODE=mock

# Trading safety
TRADING_MODE=paper
TRADING_ENABLED=false
SYMBOLS=BTC,ETH
LOOP_INTERVAL_MS=2500
ORDERBOOK_DEPTH=20
STALE_BOOK_MS=5000
MIN_EDGE_BPS=8
TAKER_FEE_BPS=0
SLIPPAGE_BUFFER_BPS=3
MIN_TRADE_USD=20
MAX_TRADE_USD=250
MAX_POSITION_USD_PER_SYMBOL=1000
MAX_DAILY_LOSS_USD=100

# Daily report
REPORT_TIME=09:00
TIMEZONE=Asia/Seoul

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cascade testnet, based on provided docs.
CASCADE_BASE_URL=https://engine.cascade.cooking
CASCADE_JWT=
CASCADE_ORDERBOOK_PATH=/orderbook
CASCADE_ORDERBOOK_QUERY_PARAM=market
CASCADE_PLACE_ORDER_PATH=/orders/place
CASCADE_CANCEL_ORDER_PATH=/orders/cancel
CASCADE_POSITIONS_PATH=/account/positions
CASCADE_MARKETS_PATH=/markets
CASCADE_MARKET_BTC=BTC-USD
CASCADE_MARKET_ETH=ETH-USD

# RISEx API, verified from official docs.
RISEX_BASE_URL=https://api.testnet.rise.trade
RISEX_API_PREFIX=/v1
RISEX_ACCOUNT=
RISEX_SIGNER=
RISEX_ENABLE_TESTNET_SERVER_SIGNING=false
RISEX_SIGNER_PRIVATE_KEY=
RISEX_MARKET_BTC=BTC-PERP
RISEX_MARKET_ETH=ETH-PERP
