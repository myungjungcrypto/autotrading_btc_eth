# Runtime
PORT=8787
HOST=127.0.0.1
NODE_ENV=development
DATA_DIR=./data
MARKET_DATA_MODE=live

# Trading safety
TRADING_MODE=paper
TRADING_ENABLED=false
SYMBOLS=BTC,ETH
EXCHANGES=cascade,risex,lighter
ROUTE_PAIRS=lighter:cascade,lighter:risex
LOOP_INTERVAL_MS=50
ORDERBOOK_DEPTH=20
STALE_BOOK_MS=15000
ENTRY_EDGE_BPS=50
EXIT_EDGE_BPS=0
TAKER_FEE_BPS=0
SLIPPAGE_BUFFER_BPS=3
MAX_BOOK_SPREAD_BPS=100
MAX_BOOK_MID_MOVE_BPS=500
MAX_CROSS_VENUE_MID_DIFF_BPS=300
MIN_TRADE_USD=20
MAX_TRADE_USD=250
MAX_POSITION_USD_PER_SYMBOL=1000
MAX_DAILY_LOSS_USD=100
SYMBOL_ERROR_LOG_INTERVAL_MS=10000

# Daily report
REPORT_TIME=09:00
TIMEZONE=Asia/Seoul

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cascade production market data, matching https://cascade.xyz/trade/BTC-USD.
# The provided Cascade testnet docs are stored in docs/exchanges/cascade.md.
CASCADE_BASE_URL=https://engine.cascade.xyz
CASCADE_JWT=
CASCADE_TIMEOUT_MS=15000
CASCADE_RESUBSCRIBE_MS=5000
CASCADE_ORDERBOOK_TRANSPORT=ws
CASCADE_WS_PATH=/ws
CASCADE_ORDERBOOK_TICK_SIZE=0.1
CASCADE_ORDERBOOK_PATH=/orderbook
CASCADE_ORDERBOOK_QUERY_PARAM=market
CASCADE_PLACE_ORDER_PATH=/orders/place
CASCADE_CANCEL_ORDER_PATH=/orders/cancel
CASCADE_POSITIONS_PATH=/account/positions
CASCADE_MARKETS_PATH=/markets
CASCADE_MARKET_BTC=BTC-USD-PERP
CASCADE_MARKET_ETH=ETH-USD-PERP

# RISEx production market data, matching https://www.rise.trade/en/trade/ETH-PERP.
RISEX_BASE_URL=https://api.rise.trade/api
RISEX_API_PREFIX=/v1
RISEX_TIMEOUT_MS=2500
RISEX_RETRIES=0
RISEX_ORDERBOOK_TRANSPORT=ws
RISEX_WS_URL=wss://api.rise.trade/ws/
RISEX_WS_RESUBSCRIBE_MS=5000
RISEX_POLL_INTERVAL_MS=1000
RISEX_RATE_LIMIT_BACKOFF_MS=10000
RISEX_LOG_INTERVAL_MS=10000
RISEX_ERROR_LOG_INTERVAL_MS=10000
RISEX_ACCOUNT=
RISEX_SIGNER=
RISEX_ENABLE_TESTNET_SERVER_SIGNING=false
RISEX_SIGNER_PRIVATE_KEY=
RISEX_MARKET_BTC=1
RISEX_MARKET_ETH=2

# Lighter production market data, matching https://app.lighter.xyz/trade/BTC.
# Lighter docs: https://apidocs.lighter.xyz/docs/websocket-reference
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_API_PREFIX=/api/v1
LIGHTER_TIMEOUT_MS=2500
LIGHTER_RETRIES=0
LIGHTER_ORDERBOOK_TRANSPORT=ws
LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream
LIGHTER_WS_RESUBSCRIBE_MS=5000
LIGHTER_WS_RECONNECT_BACKOFF_MS=10000
LIGHTER_LOG_INTERVAL_MS=10000
LIGHTER_MARKET_BTC=1
LIGHTER_MARKET_ETH=0
